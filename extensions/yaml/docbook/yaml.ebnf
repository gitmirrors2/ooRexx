/* yaml.cls — Railroad diagram EBNF grammars */
/* Feed to the Railroad Diagram Generator at https://www.bottlecaps.de/rr/ui */

/* ======================================================================== */
/* YamlError class                                                          */
/* ======================================================================== */

YamlError_init
         ::= 'init(' message ( ',' lineNumber ( ',' column ( ',' contextLine )? )? )? ')'

YamlError_makeString
         ::= 'makeString'

/* ======================================================================== */
/* YamlTagged class                                                         */
/* ======================================================================== */

YamlTagged_init
         ::= 'init(' tag ',' value ')'

YamlTagged_tag
         ::= 'tag'

YamlTagged_value
         ::= 'value'

YamlTagged_makeString
         ::= 'makeString'

/* ======================================================================== */
/* YamlBoolean class                                                        */
/* ======================================================================== */

YamlBoolean_true
         ::= 'true'

YamlBoolean_false
         ::= 'false'

YamlBoolean_activate
         ::= 'activate'

YamlBoolean_init
         ::= 'init(' value ')'

YamlBoolean_unknown
         ::= 'unknown(' messageName ',' arguments ')'

YamlBoolean_equal
         ::= '=(' other ')'

YamlBoolean_notEqual
         ::= ( '\=(' | '<>(' | '><(' ) other ')'

YamlBoolean_compareTo
         ::= 'compareTo(' other ')'

YamlBoolean_value
         ::= 'value'

YamlBoolean_makeString
         ::= 'makeString'

YamlBoolean_makeYAML
         ::= 'makeYAML'

/* ======================================================================== */
/* Yaml class — class attributes                                            */
/* ======================================================================== */

Yaml_true
         ::= 'true'

Yaml_false
         ::= 'false'

/* ======================================================================== */
/* Yaml class — instance creation                                           */
/* ======================================================================== */

Yaml_init_class
         ::= 'init'

Yaml_init
         ::= 'init(' ( unescapeUnicode ( ',' preserveTags )? )? ')'

/* ======================================================================== */
/* Yaml class — instance attributes                                         */
/* ======================================================================== */

Yaml_anchorMap
         ::= 'anchorMap'

Yaml_directivesMap
         ::= 'directivesMap'

Yaml_mergeSourceMap
         ::= 'mergeSourceMap'

/* ======================================================================== */
/* Yaml class — parsing (instance methods)                                  */
/* ======================================================================== */

Yaml_parseString
         ::= 'parseString(' input ')'

Yaml_parseFile
         ::= 'parseFile(' path ')'

Yaml_parseAll
         ::= 'parseAll(' input ')'

Yaml_parseAllFile
         ::= 'parseAllFile(' path ')'

Yaml_parseFrontMatter
         ::= 'parseFrontMatter(' input ')'

Yaml_parseFrontMatterFile
         ::= 'parseFrontMatterFile(' path ')'

Yaml_parseArray
         ::= 'parseArray(' anArray ')'

Yaml_parseXml
         ::= 'parseXml(' input ')'

Yaml_parseXmlFile
         ::= 'parseXmlFile(' path ')'

/* ======================================================================== */
/* Yaml class — tag resolution (instance methods)                           */
/* ======================================================================== */

Yaml_resolveTagHandle
         ::= 'resolveTagHandle(' tag ',' tagHandles ')'

/* ======================================================================== */
/* Yaml class — serialisation (class methods)                               */
/* ======================================================================== */

Yaml_toYaml
         ::= 'toYaml(' obj ( ',' indentSize ( ',' anchorMap ( ',' mergeSourceMap )? )? )? ')'

Yaml_toYamlAll
         ::= 'toYamlAll(' docs ( ',' indentSize ( ',' anchorMap ( ',' mergeSourceMap )? )? )? ')'

Yaml_toYamlArray
         ::= 'toYamlArray(' obj ( ',' indentSize ( ',' anchorMap ( ',' mergeSourceMap )? )? )? ')'

Yaml_toYamlFile
         ::= 'toYamlFile(' obj ',' path ( ',' indentSize ( ',' anchorMap ( ',' mergeSourceMap )? )? )? ')'

Yaml_toYamlFMFile
         ::= 'toYamlFMFile(' obj ',' path ( ',' indentSize ( ',' anchorMap ( ',' mergeSourceMap )? )? )? ')'

Yaml_yamlToXml
         ::= 'yamlToXml(' obj ( ',' schema ( ',' anchorMap ( ',' directivesMap ( ',' mergeSourceMap )? )? )? )? ')'

Yaml_yamlToXmlFile
         ::= 'yamlToXmlFile(' obj ',' path ( ',' schema ( ',' anchorMap ( ',' directivesMap ( ',' mergeSourceMap )? )? )? )? ')'

/* ======================================================================== */
/* deepEqual routine                                                        */
/* ======================================================================== */

deepEqual
         ::= 'deepEqual(' expected ',' actual ')'

/* ======================================================================== */
/* YamlEmitter class                                                        */
/* ======================================================================== */

YamlEmitter_init
         ::= 'init(' ( indentSize ( ',' anchorMap ( ',' mergeSourceMap )? )? )? ')'

YamlEmitter_emit
         ::= 'emit(' obj ')'

/* ======================================================================== */
/* YamlXmlEmitter class                                                     */
/* ======================================================================== */

YamlXmlEmitter_init
         ::= 'init(' ( schema ( ',' anchorMap ( ',' directivesMap ( ',' mergeSourceMap )? )? )? )? ')'

YamlXmlEmitter_emit
         ::= 'emit(' obj ')'

/* ======================================================================== */
/* YamlXmlParser class                                                      */
/* ======================================================================== */

YamlXmlParser_parse
         ::= 'parse(' input ')'
