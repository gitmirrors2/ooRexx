  self~assertSame('0.5', json~toJSON(.5), "enc norm: .5 -> 0.5")

::method test_enc_norm_042
  expose json
  self~assertSame('42', json~toJSON(042), "enc norm: 042 -> 42")

::method test_enc_norm_00
  expose json
  self~assertSame('0', json~toJSON(00), "enc norm: 00 -> 0")

::method test_enc_norm_large_integer
