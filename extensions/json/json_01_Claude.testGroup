/*============================================================================*/

::class json_edge_cases_test public subclass ooTestCase

::method init class
  forward class (super) continue

::method setUp
  expose json
  json = .json~new

/* --- 26. Edge cases: empty and minimal inputs --- */

::method test_edge_empty_object_roundtrip
  expose json
  self~assertSame('{}', json~toJSON(json~fromJSON('{}')), "edge: empty object round-trip")

::method test_edge_empty_array_roundtrip
